{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "incremental": true,
    "lib": ["DOM", "ES2018"],
    "module": "ESNext",
    "moduleResolution": "node",
    "noEmitOnError": true,
    "outDir": "lib",
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2018"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.spec.ts"]
}
