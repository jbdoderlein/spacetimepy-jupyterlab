{
  "name": "spacetimepy-jupyterlab",
  "version": "0.1.0",
  "description": "Exploratory notebook controls and side panel for JupyterLab.",
  "homepage": "https://github.com/example/spacetimepy-jupyterlab",
  "bugs": {
    "url": "https://github.com/example/spacetimepy-jupyterlab/issues"
  },
  "license": "BSD-3-Clause",
  "author": "spacetimepy contributors",
  "sideEffects": [
    "style/*.css"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "files": [
    "lib/**/*.{js,js.map,d.ts,d.ts.map}",
    "style/index.css"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:labextension:dev",
    "build:prod": "npm run build:lib && npm run build:labextension",
    "build:lib": "tsc",
    "build:labextension": "XDG_CACHE_HOME=.cache jupyter-builder build .",
    "build:labextension:dev": "XDG_CACHE_HOME=.cache jupyter-builder build --development=True .",
    "clean": "rimraf lib tsconfig.tsbuildinfo .cache spacetimepy_jupyterlab/labextension",
    "generate:kernel-code": "node scripts/generate-kernel-code.mjs",
    "prebuild:lib": "npm run generate:kernel-code",
    "pretest": "npm run generate:kernel-code",
    "test": "vitest run src"
  },
  "dependencies": {
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.2",
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/cells": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@lumino/widgets": "^2.0.0",
    "d3-hierarchy": "^3.1.2"
  },
  "devDependencies": {
    "@jupyter/builder": "^1.0.2",
    "@types/d3-hierarchy": "^3.1.7",
    "rimraf": "^5.0.0",
    "typescript": "~5.6.0",
    "vitest": "^4.1.10"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "spacetimepy_jupyterlab/labextension"
  }
}
