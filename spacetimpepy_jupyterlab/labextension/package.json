{
  "name": "spacetimpepy-jupyterlab",
  "version": "0.1.0",
  "description": "Exploratory notebook controls and side panel for JupyterLab.",
  "homepage": "https://github.com/example/spacetimpepy-jupyterlab",
  "bugs": {
    "url": "https://github.com/example/spacetimpepy-jupyterlab/issues"
  },
  "license": "BSD-3-Clause",
  "author": "spacetimpepy contributors",
  "sideEffects": [
    "style/*.css"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "files": [
    "lib/**/*.{js,js.map,d.ts,d.ts.map}",
    "style/index.css"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:labextension:dev",
    "build:prod": "npm run build:lib && npm run build:labextension",
    "build:lib": "tsc",
    "build:labextension": "XDG_CACHE_HOME=.cache jupyter-builder build .",
    "build:labextension:dev": "XDG_CACHE_HOME=.cache jupyter-builder build --development=True .",
    "clean": "rimraf lib tsconfig.tsbuildinfo .cache spacetimpepy_jupyterlab/labextension"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@lumino/widgets": "^2.0.0"
  },
  "devDependencies": {
    "@jupyter/builder": "^1.0.2",
    "rimraf": "^5.0.0",
    "typescript": "~5.6.0"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "spacetimpepy_jupyterlab/labextension",
    "_build": {
      "load": "static/remoteEntry.4bed3ddd05f6df11.js",
      "extension": "./extension",
      "style": "./style"
    }
  }
}
